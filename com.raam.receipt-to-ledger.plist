<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.raam.receipt-to-ledger</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Update this path to wherever you installed the venv -->
        <string>/Users/raam/.venvs/receipt-to-ledger/bin/python</string>
        <string>/Users/raam/scripts/receipt_to_ledger.py</string>
    </array>

    <!-- API key and paths are read from ~/.receipt-to-ledger.conf — nothing sensitive here -->

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/raam/logs/receipt_to_ledger.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/raam/logs/receipt_to_ledger.stderr.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
